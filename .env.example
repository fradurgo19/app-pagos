# Copiar a .env (no subir a git). Variables opcionales para el interruptor de app provisional.

# --- App provisional (prioridad sobre el default del código) ---
# true  = app desactivada (pantalla de mantenimiento, API 503)
# false = app activa (login y facturas normales)
# VITE_AUTH_DISABLED=true
# AUTH_DISABLED=true

# URL de la nueva app (botón en pantalla de mantenimiento)
# VITE_SUNSET_APP_URL=https://tu-nueva-app.vercel.app

# --- API / Supabase (app activa) ---
# VITE_API_URL=http://localhost:3000
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# JWT_SECRET=
# DATABASE_URL=
# SUPABASE_SERVICE_KEY=
